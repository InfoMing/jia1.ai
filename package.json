{
  "name": "super-i",
  "version": "1.0.1",
  "description": "刺猬星球 Super-i 极简前台",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:stage": "vite build --mode staging",
    "preview": "vite preview",
    "lint": "eslint src/business src/router/business.js tests vitest.config.js playwright.config.js",
    "lint:fix": "eslint src/business src/router/business.js tests vitest.config.js playwright.config.js --fix",
    "lint:all": "eslint src --ext .vue,.js",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "vue": "^3.5.39",
    "vue-router": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^29.1.1",
    "sass": "^1.83.4",
    "vite": "^6.3.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
